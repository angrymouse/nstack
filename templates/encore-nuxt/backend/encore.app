{
  "id": "__APP_SLUG__",
  "lang": "typescript",
  "global_cors": {
    "allow_origins_with_credentials": [
      "http://localhost:3000",
      "http://127.0.0.1:3000"
    ],
    "allow_headers": [
      "Authorization",
      "Content-Type",
      "X-Requested-With"
    ],
    "expose_headers": [
      "x-encore-trace-id"
    ]
  }
}
