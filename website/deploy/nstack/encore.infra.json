{
  "$schema": "https://encore.dev/schemas/infra.schema.json",
  "metadata": {
    "app_id": "nstack",
    "env_name": "prod",
    "env_type": "production",
    "cloud": "local",
    "base_url": "https://nstack.tech/api"
  },
  "graceful_shutdown": {
    "total": 30
  },
  "hosted_services": [
    "api"
  ],
  "hosted_gateways": [
    "api-gateway"
  ],
  "cors": {
    "allow_origins_with_credentials": [
      "https://nstack.tech"
    ],
    "allow_headers": [
      "Authorization",
      "Content-Type",
      "X-Requested-With"
    ],
    "expose_headers": [
      "x-encore-trace-id",
      "X-Request-Id"
    ]
  },
  "secrets": {
    "NSTACK_RELEASE_DISCORD_WEBHOOK_URL": {
      "$env": "NSTACK_RELEASE_DISCORD_WEBHOOK_URL"
    }
  },
  "redis": {
    "release-metadata": {
      "host": "nstack-redis-ryoug1:6379",
      "database_index": 0,
      "key_prefix": "nstack:release-metadata:",
      "in_memory": false,
      "tls_config": {
        "disabled": true
      },
      "auth": {
        "type": "auth_string",
        "auth_string": {
          "$env": "NSTACK_REDIS_PASSWORD"
        }
      }
    }
  }
}
